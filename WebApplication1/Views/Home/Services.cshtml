@{
    ViewData["Title"] = "Services";
}

<!-- Page Header -->
<div class="container-fluid page-header py-5 header-img">
    <div class="container py-5 text-center text-white">
        <h1 class="display-3 mb-3 animate fw-bold">Our Services</h1>
        <p class="lead animate">Global logistics solutions designed for speed, safety, and reliability</p>

        <nav>
            <ol class="breadcrumb justify-content-center">
                <li class="breadcrumb-item">
                    <a class="text-white" asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <li class="breadcrumb-item text-white active">Services</li>
            </ol>
        </nav>
    </div>
</div>

<!-- SERVICES -->
<div class="container-xxl py-5">
    <div class="container py-5">

        <div class="text-center mb-5 animate">
            <h6 class="text-primary text-uppercase fw-bold">What We Offer</h6>
            <h1 class="fw-bold">Complete Logistics & Supply Chain Solutions</h1>
            <p class="text-muted">From air freight to warehousing, we deliver end-to-end logistics services worldwide.</p>
        </div>

        <div class="row g-4">

            <!-- SERVICE CARDS -->
            <script>
                const services = [
                    ["Air Freight", "Fast international air cargo delivery.", "We provide secure, time-critical air transport across global airports."],
                    ["Ocean Freight", "Global sea shipping solutions.", "Cost-effective container shipping for bulk international cargo."],
                    ["Road Freight", "Reliable truck transportation.", "Nationwide and cross-border trucking with real-time tracking."],
                    ["Rail Freight", "Eco-friendly rail logistics.", "Efficient rail transport for heavy and long-distance cargo."],
                    ["Warehousing", "Secure storage facilities.", "Modern warehouses with inventory tracking and management systems."],
                    ["Customs Clearance", "Fast import/export processing.", "We handle all customs documentation and border clearance."],
                    ["Express Delivery", "Same-day & next-day delivery.", "Ultra-fast courier services for urgent shipments."],
                    ["Cold Chain Logistics", "Temperature-controlled transport.", "Safe delivery for pharmaceuticals and food products."],
                    ["E-commerce Logistics", "Online store fulfillment.", "Complete order packing, shipping, and delivery solutions."],
                    ["Supply Chain Management", "End-to-end logistics planning.", "Optimize your entire supply chain for efficiency."],
                    ["Heavy Cargo Transport", "Oversized shipment handling.", "Specialized equipment for heavy industrial cargo."],
                    ["Tracking & Monitoring", "Real-time shipment tracking.", "Live GPS tracking and status updates for all deliveries."]
                ];
            </script>

            <!-- CARDS -->
            @for (int i = 0; i < 12; i++)
            {
                <div class="col-md-6 col-lg-4 animate">
                    <div class="service-card">

                        <div class="img-box">
                            <img src="/img/service-@(i % 6 + 1).jpg" />
                        </div>

                        <div class="p-4">
                            <h4>@Html.Raw($"Service {i + 1}")</h4>

                            <p>
                                @Html.Raw(i switch {
                                    0 => "Fast international air cargo delivery.",
                                    1 => "Global sea shipping solutions.",
                                    2 => "Reliable truck transportation.",
                                    3 => "Eco-friendly rail logistics.",
                                    4 => "Secure storage facilities.",
                                    5 => "Fast import/export processing.",
                                    6 => "Same-day & next-day delivery.",
                                    7 => "Temperature-controlled transport.",
                                    8 => "Online store fulfillment.",
                                    9 => "End-to-end logistics planning.",
                                    10 => "Oversized shipment handling.",
                                    _ => "Real-time shipment tracking."
                                })
                            </p>

                            <button class="btn btn-link"
                                    onclick="openModal(services[@i][0], services[@i][2])">
                                Read More →
                            </button>
                        </div>

                    </div>
                </div>
            }

        </div>
    </div>
</div>

<!-- MODAL -->
<div id="serviceModal" class="modal-overlay">
    <div class="modal-box animate">
        <h3 id="modalTitle"></h3>
        <p id="modalText"></p>
        <button class="btn btn-danger mt-3" onclick="closeModal()">Close</button>
    </div>
</div>

<!-- STYLES -->
<style>

/* HEADER */
.header-img {
    background: linear-gradient(rgba(0,0,0,.75), rgba(0,0,0,.75)),
                url('/img/carousel-1.jpg') center/cover no-repeat;
}

/* CARD */
.service-card {
    background: #fff;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    transition: 0.4s;
}

.service-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.2);
}

/* IMAGE */
.img-box {
    overflow: hidden;
}

.img-box img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    transition: 0.5s;
}

.service-card:hover img {
    transform: scale(1.1);
}

/* MODAL */
.modal-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.6);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 9999;
}

.modal-box {
    background: white;
    padding: 25px;
    border-radius: 12px;
    width: 380px;
    text-align: center;
}

/* ANIMATION */
.animate {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s ease;
}

.animate.show {
    opacity: 1;
    transform: translateY(0);
}

</style>

<!-- SCRIPT -->
<script>

// scroll animation
document.addEventListener("DOMContentLoaded", function () {

    const elements = document.querySelectorAll(".animate");

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add("show");
            }
        });
    });

    elements.forEach(el => observer.observe(el));
});

// modal open
function openModal(title, text) {
    document.getElementById("modalTitle").innerText = title;
    document.getElementById("modalText").innerText = text;
    document.getElementById("serviceModal").style.display = "flex";
}

// modal close
function closeModal() {
    document.getElementById("serviceModal").style.display = "none";
}

</script>