@{
    Layout = null;
    ViewData["Title"] = "Verify OTP";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Verify OTP</title>

    <style>
            body {
                margin: 0;
                font-family: 'Segoe UI', sans-serif;
                background: radial-gradient(circle at top, #0b0b0b, #000);
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
            }

            .bg-glow {
                position: absolute;
                width: 500px;
                height: 500px;
                background: #ff6a00;
                filter: blur(140px);
                opacity: 0.15;
                border-radius: 50%;
                top: 20%;
                left: 30%;
            }

            .card {
                width: 420px;
                padding: 40px;
                border-radius: 18px;
                background: rgba(255, 106, 0, 0.06);
                border: 1px solid rgba(255, 106, 0, 0.25);
                box-shadow: 0 0 60px rgba(255, 106, 0, 0.15);
                backdrop-filter: blur(20px);
                text-align: center;
                position: relative;
                z-index: 2;
            }

            .logo {
                width: 90px;
                margin-bottom: 15px;
            }

            .title {
                font-size: 26px;
                font-weight: bold;
                color: #ff7a18;
            }

            .subtitle {
                font-size: 13px;
                opacity: 0.7;
                margin-bottom: 20px;
            }

            .input {
                width: 100%;
                padding: 14px;
                border-radius: 10px;
                border: 1px solid rgba(255, 106, 0, 0.3);
                background: rgba(0,0,0,0.5);
                color: white;
                text-align: center;
                letter-spacing: 6px;
                font-size: 16px;
                outline: none;
            }

            .btn {
                width: 100%;
                margin-top: 15px;
                padding: 14px;
                border: none;
                border-radius: 10px;
                background: linear-gradient(135deg, #ff7a18, #ff3c00);
                color: black;
                font-weight: bold;
                cursor: pointer;
            }

                .btn:hover {
                    transform: scale(1.02);
                }

            .error {
                margin-top: 10px;
                color: #ff4d4d;
                font-size: 13px;
            }

            .back {
                display: block;
                margin-top: 15px;
                color: #ff7a18;
                text-decoration: none;
                font-size: 13px;
            }
    </style>
</head>

<body>

    <div class="bg-glow"></div>

    <div class="card">

        <img src="~/img/logistic.png" class="logo" />

        <div class="title">Verify OTP</div>
        <div class="subtitle">Enter the 6-digit code sent to your email</div>

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

        <!-- FIXED FORM -->
        <form method="post" asp-controller="Auth" asp-action="VerifyOtp">

            <input name="otp" class="input" placeholder="------" maxlength="6" required />

            <button type="submit" class="btn">Verify</button>

        </form>

        <a href="/Auth/Login" class="back">← Back to Login</a>

    </div>

</body>
</html>