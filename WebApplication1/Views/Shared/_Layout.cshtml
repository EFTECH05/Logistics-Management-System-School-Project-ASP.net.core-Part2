<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Logistica</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body { margin: 0; padding: 0; }

        .logo-circle {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #0d6efd;
        }

        .navbar {
            z-index: 9999;
            position: relative;
        }

        .tracking-bar {
            background: #0b0f1a;
            padding: 10px 0;
            color: white;
            font-size: 13px;
        }

        .tracking-steps {
            display: flex;
            justify-content: space-between;
            position: relative;
            max-width: 900px;
            margin: auto;
        }

        .tracking-steps::before {
            content: "";
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 3px;
            background: #2c2f3a;
        }

        .progress-line {
            position: absolute;
            top: 50%;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, #ffc107, #ff4d4d);
            width: 0%;
            animation: loadProgress 6s infinite;
        }

        @@keyframes loadProgress {
            0% { width: 0%; }
            100% { width: 100%; }
        }

        .step { width: 20%; text-align: center; z-index: 2; }
        .step i { font-size: 18px; color: #6c757d; }
        .step.active i { color: #ffc107; }

        .footer-dark {
            background: linear-gradient(135deg, #0b0f1a, #111827, #0b0f1a);
            color: white;
        }

        .footer-dark a {
            color: rgba(255,255,255,0.75);
            text-decoration: none;
            transition: 0.3s;
        }

        .footer-dark a:hover {
            color: #ffc107;
            transform: translateX(5px);
        }

        .social-icon {
            font-size: 20px;
            color: white;
            transition: 0.3s;
            cursor: pointer;
        }

        .social-icon:hover {
            color: #ffc107;
            transform: scale(1.2);
        }

        .robot-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #ffc107;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            cursor: pointer;
            z-index: 999;
        }

        .chat-box {
            position: fixed;
            bottom: 90px;
            right: 20px;
            width: 320px;
            background: white;
            border-radius: 12px;
            display: none;
            flex-direction: column;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            z-index: 999;
        }

        .chat-header {
            background: #0d6efd;
            color: white;
            padding: 10px;
            font-weight: bold;
            border-radius: 12px 12px 0 0;
        }

        .chat-body {
            height: 220px;
            padding: 10px;
            overflow-y: auto;
            font-size: 14px;
        }

        .chat-footer {
            display: flex;
            border-top: 1px solid #ddd;
        }

        .chat-footer input {
            flex: 1;
            border: none;
            padding: 10px;
            outline: none;
        }

        .chat-footer button {
            background: #0d6efd;
            color: white;
            border: none;
            padding: 10px 15px;
        }
    </style>
</head>

<body>

<!-- TRACKING BAR -->
<div class="tracking-bar">
    <div class="container">
        <div class="tracking-steps">
            <div class="progress-line"></div>

            <div class="step active"><i class="bi bi-box"></i><div>Order</div></div>
            <div class="step active"><i class="bi bi-building"></i><div>Warehouse</div></div>
            <div class="step active"><i class="bi bi-truck"></i><div>Transit</div></div>
            <div class="step"><i class="bi bi-box-seam"></i><div>Out</div></div>
            <div class="step"><i class="bi bi-check-circle"></i><div>Delivered</div></div>
        </div>
    </div>
</div>

<!-- NAVBAR -->
<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
        <div class="container">

            <a class="navbar-brand fw-bold d-flex align-items-center gap-2"
               asp-controller="Home"
               asp-action="Index">
                <img src="~/img/logistic.png" class="logo-circle" />
                Logistica
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Services">Services</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Quote">Quote</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="ContactUs">Contact Us</a></li>
                </ul>

                <div class="d-flex gap-2">
                        <a class="btn btn-outline-primary btn-sm" href="/Auth/Login">Login</a>
                        <a class="btn btn-primary btn-sm" href="/Auth/Register">Register</a>
                </div>

            </div>
        </div>
    </nav>
</header>

<!-- CONTENT -->
<main>
    @RenderBody()
</main>

<!-- FOOTER -->
<footer class="footer-dark pt-5 pb-4 mt-5">
    <div class="container">
        <div class="row g-4">

            <div class="col-md-3">
                <img src="~/img/logistic.png" class="logo-circle mb-3" />
                <p>Global logistics solutions trusted worldwide.</p>
            </div>

            <div class="col-md-3">
                <h6 class="text-warning">Quick Links</h6>
                <p><a asp-controller="Home" asp-action="Index">Home</a></p>
                <p><a asp-controller="Home" asp-action="About">About</a></p>
                <p><a asp-controller="Home" asp-action="Services">Services</a></p>
            </div>

            <div class="col-md-3">
                <h6 class="text-warning">Contact</h6>
                <p>📍 Cape Town</p>
                <p>📞 +27 00 000 0000</p>
            </div>

            <div class="col-md-3">
                <h6 class="text-warning">Newsletter</h6>
                <input class="form-control mb-2" placeholder="Email" />
                <button class="btn btn-warning w-100">Subscribe</button>
            </div>

        </div>

        <hr class="border-secondary mt-4" />
        <div class="text-center">© 2026 Logistica - Developed by Franklin Ngangu</div>
    </div>
</footer>

<!-- CHAT -->
<div class="robot-btn" onclick="toggleChat()">🤖</div>

<div class="chat-box" id="chatBox">
    <div class="chat-header">Logistica AI Bot</div>

    <div class="chat-body" id="chatBody">
        <p><b>Bot:</b> Hello 👋 How can I help you?</p>
    </div>

    <div class="chat-footer">
        <input type="text" id="msgInput" placeholder="Type..." />
        <button onclick="sendMsg()">Send</button>
    </div>
</div>

<script>
function toggleChat() {
    let box = document.getElementById("chatBox");
    box.style.display = (box.style.display === "flex") ? "none" : "flex";
}

function sendMsg() {
    let input = document.getElementById("msgInput");
    let chat = document.getElementById("chatBody");

    if (input.value.trim() !== "") {
        chat.innerHTML += "<p><b>You:</b> " + input.value + "</p>";

        setTimeout(() => {
            chat.innerHTML += "<p><b>Bot:</b> We received your message 🚚</p>";
        }, 500);

        input.value = "";
    }
}
</script>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>

