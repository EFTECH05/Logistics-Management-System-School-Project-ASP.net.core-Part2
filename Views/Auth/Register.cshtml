@model WebApplication1.Models.User

@{
    Layout = null;
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register</title>

    <style>
            body {
                margin: 0;
                font-family: 'Segoe UI', sans-serif;
                background: radial-gradient(circle at top, #111, #000);
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
            }

            .container {
                display: flex;
                width: 1000px;
                max-width: 95%;
                border-radius: 22px;
                overflow: hidden;
                background: rgba(255, 140, 0, 0.05);
                backdrop-filter: blur(25px);
                box-shadow: 0 40px 120px rgba(0,0,0,0.9);
                border: 1px solid rgba(255, 140, 0, 0.2);
            }

            /* LEFT SIDE */
            .left {
                flex: 1;
                padding: 60px;
                background: linear-gradient(135deg, #ff7a00, #ff3c00);
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                position: relative;
            }

                .left::after {
                    content: "";
                    position: absolute;
                    width: 250px;
                    height: 250px;
                    background: rgba(0,0,0,0.25);
                    filter: blur(90px);
                    border-radius: 50%;
                    top: 20%;
                    left: 20%;
                }

                .left h1 {
                    font-size: 32px;
                    z-index: 2;
                    margin-bottom: 10px;
                }

                .left p {
                    text-align: center;
                    opacity: 0.9;
                    max-width: 300px;
                    z-index: 2;
                }

            /* RIGHT SIDE */
            .right {
                flex: 1;
                padding: 60px;
            }

            .title {
                font-size: 30px;
                font-weight: bold;
                color: #ff7a00;
            }

            .subtitle {
                font-size: 13px;
                opacity: 0.7;
                margin-bottom: 25px;
            }

            .field {
                margin-bottom: 18px;
            }

                .field input {
                    width: 100%;
                    padding: 14px;
                    border-radius: 12px;
                    border: 1px solid rgba(255, 140, 0, 0.3);
                    background: rgba(0,0,0,0.6);
                    color: white;
                    outline: none;
                    transition: 0.3s;
                }

                    .field input:focus {
                        border-color: #ff7a00;
                        box-shadow: 0 0 0 3px rgba(255,122,0,0.2);
                    }

            .btn {
                width: 100%;
                padding: 14px;
                border-radius: 12px;
                border: none;
                background: linear-gradient(135deg, #ff7a00, #ff3c00);
                color: black;
                font-weight: bold;
                cursor: pointer;
                transition: 0.3s;
            }

                .btn:hover {
                    transform: scale(1.03);
                    box-shadow: 0 15px 40px rgba(255,122,0,0.35);
                }

            .footer {
                margin-top: 15px;
                text-align: center;
                font-size: 13px;
            }

                .footer a {
                    color: #ff7a00;
                    text-decoration: none;
                    font-weight: bold;
                }

            .error {
                background: rgba(255,0,0,0.15);
                padding: 10px;
                border-radius: 10px;
                margin-bottom: 10px;
                color: #ff6b6b;
            }

            .success {
                background: rgba(255,122,0,0.15);
                padding: 10px;
                border-radius: 10px;
                margin-bottom: 10px;
                color: #ff7a00;
            }

            @@media (max-width: 768px) {
                .container {
                    flex-direction: column;
                }

                .left {
                    text-align: center;
                }
            }
    </style>
</head>

<body>

    <div class="container">

        <!-- LEFT -->
        <div class="left">
            <h1>Join Logistica </h1>
            <p>Create your account and start managing deliveries, tracking, and logistics operations.</p>
        </div>

        <!-- RIGHT -->
        <div class="right">

            <div class="title">Create Account</div>
            <div class="subtitle">Register your logistica account</div>

            @if (ViewBag.Error != null)
            {
                <div class="error">@ViewBag.Error</div>
            }

            @if (TempData["Success"] != null)
            {
                <div class="success">@TempData["Success"]</div>
            }

            <form method="post" asp-action="Register" asp-controller="Auth">

                <div class="field">
                    <input asp-for="FullName" placeholder="Full Name" required />
                </div>

                <div class="field">
                    <input asp-for="Username" placeholder="Username" required />
                </div>

                <div class="field">
                    <input asp-for="Email" placeholder="Email Address" required />
                </div>

                <div class="field">
                    <input asp-for="Password" type="password" placeholder="Password" required />
                </div>

                <button type="submit" class="btn">Create Account</button>

            </form>

            <div class="footer">
                Already have an account?
                <a href="/Auth/Login">Login</a>
            </div>

        </div>

    </div>

</body>
</html>