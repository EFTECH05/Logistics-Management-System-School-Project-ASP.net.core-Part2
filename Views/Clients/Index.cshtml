@model IEnumerable<WebApplication1.Models.Client>

@{
    Layout = null; // ❗ removes navbar/footer
    ViewData["Title"] = "Clients";
}

<style>
    body {
        margin: 0;
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        background: radial-gradient(circle at top, #1e293b, #0f172a);
        color: white;
        padding: 40px;
    }

    .container {
        max-width: 1100px;
        margin: auto;
        animation: fadeIn 0.5s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* HEADER */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

        .header h1 {
            font-size: 28px;
        }

    .btn-add {
        background: linear-gradient(90deg, #22c55e, #16a34a);
        padding: 10px 15px;
        border-radius: 10px;
        color: white;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-add:hover {
            transform: scale(1.05);
            opacity: 0.9;
        }

    /* TABLE */
    table {
        width: 100%;
        border-collapse: collapse;
        background: rgba(255,255,255,0.06);
        backdrop-filter: blur(20px);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    th, td {
        padding: 15px;
        text-align: left;
    }

    th {
        background: rgba(255,255,255,0.1);
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    tr {
        transition: 0.2s;
    }

        tr:hover {
            background: rgba(255,255,255,0.08);
        }

    /* ACTION BUTTONS */
    .btn {
        padding: 6px 10px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 13px;
        margin-right: 5px;
        display: inline-block;
    }

    .edit {
        background: #3b82f6;
        color: white;
    }

    .delete {
        background: #ef4444;
        color: white;
    }

    .details {
        background: #facc15;
        color: black;
    }

    .btn:hover {
        opacity: 0.8;
        transform: scale(1.05);
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .back {
        background: #64748b;
        padding: 10px 15px;
        border-radius: 10px;
        text-decoration: none;
        color: white;
        font-weight: bold;
    }
</style>

<div class="container">

    <!-- TOP BAR -->
    <div class="top-bar">
        <a href="/Admin/Index" class="back">← Back</a>
        <a href="/Clients/Create" class="btn-add">+ Add Client</a>
    </div>

    <!-- HEADER -->
    <div class="header">
        <h1>Clients Management</h1>
    </div>

    <!-- TABLE -->
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th> contact type</th>
                <th>Name </th>
                <th>Region</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ClientId</td>
                    <td>@item.Name</td>
                    <td>@item.ContactDetails</td>
                    <td>@item.Region</td>
                    <td>
                        <a class="btn edit" href="/Clients/Edit/@item.ClientId">Edit</a>
                        <a class="btn details" href="/Clients/Details/@item.ClientId">View</a>
                        <a class="btn delete" href="/Clients/Delete/@item.ClientId">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>