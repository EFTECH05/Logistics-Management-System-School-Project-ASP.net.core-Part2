@model WebApplication1.Models.Client

@{
    Layout = null;
    ViewData["Title"] = "Delete Client";
}

<style>
    body {
        margin: 0;
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        background: radial-gradient(circle at top, #1e293b, #0f172a);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card {
        width: 450px;
        padding: 30px;
        border-radius: 18px;
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(20px);
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        text-align: center;
    }

    h2 {
        margin-bottom: 15px;
    }

    .danger-text {
        color: #ef4444;
        font-weight: bold;
        margin-bottom: 15px;
    }

    .btn {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        border: none;
        font-weight: bold;
        cursor: pointer;
        color: white;
        transition: 0.3s;
        margin-top: 10px;
    }

    .btn-delete {
        background: linear-gradient(90deg, #ef4444, #dc2626);
    }

        .btn-delete:hover {
            transform: scale(1.03);
        }

    .back {
        display: block;
        margin-top: 15px;
        color: #fbbf24;
        text-decoration: none;
    }
</style>

<div class="card">

    <h2>🗑 Delete Client</h2>

    <div class="danger-text">
        Are you sure you want to delete this client?
    </div>

    <p><b>Contact:</b> @Model.Name</p>
    <p><b>Name:</b> @Model.ContactDetails</p>
    <p><b>Region:</b> @Model.Region</p>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="ClientId" />
        <button type="submit" class="btn btn-delete">Yes, Delete</button>
    </form>

    <a href="/Clients/Index" class="back">← Cancel</a>

</div>