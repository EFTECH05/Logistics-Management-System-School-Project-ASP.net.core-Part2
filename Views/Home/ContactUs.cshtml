@{
    ViewData["Title"] = "Contact Us";
}

<!-- PAGE HEADER -->
<div class="container-fluid page-header py-5 header-img">
    <div class="container py-5 text-center text-white">
        <h1 class="display-3 mb-3 fw-bold animate">Contact Us</h1>
        <nav>
            <ol class="breadcrumb justify-content-center">
                <li class="breadcrumb-item">
                    <a class="text-white" asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <li class="breadcrumb-item text-white active">Contact</li>
            </ol>
        </nav>
    </div>
</div>

<!-- CONTACT SECTION -->
<div class="container-xxl py-5">
    <div class="container">

        <div class="text-center mb-5 animate">
            <h6 class="text-primary text-uppercase fw-bold">Get In Touch</h6>
            <h1 class="fw-bold">We’re Here To Help You</h1>
            <p class="text-muted">Send us a message and we’ll respond as soon as possible.</p>
        </div>

        <div class="row g-5">

            <!-- FORM -->
            <div class="col-lg-6 animate">
                <div class="contact-card p-4 shadow rounded">

                    <form>
                        <div class="row g-3">

                            <div class="col-md-6">
                                <input class="form-control input-custom" placeholder="Your Name" />
                            </div>

                            <div class="col-md-6">
                                <input class="form-control input-custom" placeholder="Your Email" />
                            </div>

                            <div class="col-12">
                                <input class="form-control input-custom" placeholder="Subject" />
                            </div>

                            <div class="col-12">
                                <textarea class="form-control input-custom" rows="5" placeholder="Your Message"></textarea>
                            </div>

                            <div class="col-12">
                                <button class="btn btn-primary w-100 btn-lg btn-animate">
                                    Send Message
                                </button>
                            </div>

                        </div>
                    </form>

                </div>
            </div>

            <!-- MAP -->
            <div class="col-lg-6 animate">
                <div class="map-card shadow rounded overflow-hidden">

                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d13246.345678!2d18.4241!3d-33.9249!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1dcc5d0b4a0b1f3b%3A0x3c5c2f3a1c9c8f0!2sCape%20Town%2C%20South%20Africa!5e0!3m2!1sen!2sza!4v0000000000"
                        width="100%" height="100%" style="border:0; min-height: 420px;"
                        allowfullscreen="" loading="lazy">
                    </iframe>

                </div>
            </div>

        </div>
    </div>
</div>

<!-- CONTACT INFO -->
<div class="container py-5">
    <div class="row text-center g-4">

        <div class="col-md-4 animate">
            <div class="info-box p-4 shadow rounded">
                <i class="bi bi-geo-alt fs-2 text-primary"></i>
                <h5 class="mt-3">Location</h5>
                <p>Cape Town, South Africa</p>
            </div>
        </div>

        <div class="col-md-4 animate">
            <div class="info-box p-4 shadow rounded">
                <i class="bi bi-telephone fs-2 text-primary"></i>
                <h5 class="mt-3">Phone</h5>
                <p>+27 00 000 0000</p>
            </div>
        </div>

        <div class="col-md-4 animate">
            <div class="info-box p-4 shadow rounded">
                <i class="bi bi-envelope fs-2 text-primary"></i>
                <h5 class="mt-3">Email</h5>
                <p>support@logistica.com</p>
            </div>
        </div>

    </div>
</div>

<!-- STYLES -->
<style>

/* HEADER */
.header-img {
    background: linear-gradient(rgba(0,0,0,.7), rgba(0,0,0,.7)),
                url('/img/carousel-1.jpg') center/cover no-repeat;
}

/* FORM CARD */
.contact-card {
    background: #fff;
    transition: 0.3s;
}

.contact-card:hover {
    transform: translateY(-5px);
}

/* INPUT */
.input-custom {
    height: 50px;
    border-radius: 8px;
    transition: 0.3s;
}

.input-custom:focus {
    box-shadow: 0 0 12px rgba(13,110,253,.3);
    transform: scale(1.02);
}

/* MAP */
.map-card {
    height: 100%;
    min-height: 420px;
    transition: 0.3s;
}

.map-card:hover {
    transform: scale(1.02);
}

/* INFO BOX */
.info-box {
    background: #fff;
    transition: 0.3s;
}

.info-box:hover {
    transform: translateY(-8px);
    background: #f8f9fa;
}

/* BUTTON */
.btn-animate {
    transition: 0.3s;
}

.btn-animate:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}

/* ANIMATION */
.animate {
    opacity: 0;
    transform: translateY(40px);
    transition: 0.8s ease;
}

.animate.show {
    opacity: 1;
    transform: translateY(0);
}

</style>

<!-- ANIMATION SCRIPT -->
<script>
document.addEventListener("DOMContentLoaded", function () {

    const elements = document.querySelectorAll(".animate");

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add("show");
            }
        });
    }, { threshold: 0.2 });

    elements.forEach(el => observer.observe(el));
});
</script>