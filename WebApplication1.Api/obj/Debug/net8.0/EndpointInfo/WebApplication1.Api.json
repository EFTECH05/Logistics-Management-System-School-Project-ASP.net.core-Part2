  "components": {
    "schemas": {
      "Client": {
        "required": [
          "contactDetails",
          "name",
          "region"
        ],
        "type": "object",
        "properties": {
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "contactDetails": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "region": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "contracts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contract"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Contract": {
        "required": [
          "clientId",
          "endDate",
          "serviceLevel",
          "startDate",
          "status"
        ],
        "type": "object",
        "properties": {
          "contractId": {
            "type": "integer",
            "format": "int32"
          },
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "client": {
            "$ref": "#/components/schemas/Client"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "serviceLevel": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "status": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "pdfPath": {
            "type": "string",
            "nullable": true
          },
          "serviceRequests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ServiceRequest"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ServiceRequest": {
        "required": [
          "contractId",
          "description"
        ],
        "type": "object",
        "properties": {
          "requestId": {
            "type": "integer",
            "format": "int32"
          },
          "contractId": {
            "type": "integer",
            "format": "int32"
          },
          "contract": {
            "$ref": "#/components/schemas/Contract"
          },
          "description": {
            "maxLength": 250,
            "minLength": 0,
            "type": "string"
          },
          "costUSD": {
            "type": "number",
            "format": "double"
          },
          "costZAR": {
            "type": "number",
            "format": "double"
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "createdDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "nullable": true
          },
          "tempOtp": {
            "type": "string",
            "nullable": true
          },
          "otpExpiry": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
